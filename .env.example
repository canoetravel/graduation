MYSQL_SERVER=localhost
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=os_judge
MYSQL_PORT=3306

# AI plagiarism review
# Default mode is heuristic, which works without any external model.
AI_PLAGIARISM_PROVIDER=heuristic
AI_PLAGIARISM_MODEL=heuristic-v1
AI_PLAGIARISM_BASE_URL=
AI_PLAGIARISM_API_KEY=
AI_PLAGIARISM_TIMEOUT=30

# Example for a local Ollama model:
# AI_PLAGIARISM_PROVIDER=ollama
# AI_PLAGIARISM_MODEL=qwen2.5-coder:7b
# AI_PLAGIARISM_BASE_URL=http://host.docker.internal:11434/api/chat

# Example for an OpenAI-compatible endpoint:
# AI_PLAGIARISM_PROVIDER=openai_compatible
# AI_PLAGIARISM_MODEL=gpt-4o-mini
# AI_PLAGIARISM_BASE_URL=https://your-gateway.example.com/v1/chat/completions
# AI_PLAGIARISM_API_KEY=sk-xxxx
